# Copy to .env and adjust. All values have safe local defaults in settings.py.
SECRET_KEY=dev-insecure-change-me
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,backend
FRONTEND_URL=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Path to the sqlite file. In Docker this points at a mounted volume.
DATABASE_PATH=db.sqlite3

# Payment gateway driver: "mock" (local, no internet) or "zarinpal" (sandbox).
PAYMENT_GATEWAY=mock
ZARINPAL_MERCHANT_ID=00000000-0000-0000-0000-000000000000
ZARINPAL_SANDBOX=true

# Artist reward formula (تومان). reward = streams*PER_STREAM + listeners*PER_LISTENER
REWARD_PER_STREAM=5
REWARD_PER_LISTENER=120
